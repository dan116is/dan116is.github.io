# Database
DATABASE_URL="postgresql://user:password@localhost:5432/virtualcity"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# JWT Secret (for custom auth sessions)
SESSION_SECRET="your-secret-key-minimum-32-chars-here"

# Stripe (for real payment processing)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# KYC Provider (e.g., Onfido, Jumio, or Veriff)
KYC_PROVIDER_API_KEY="your-kyc-api-key"
KYC_WEBHOOK_SECRET="your-kyc-webhook-secret"

# AWS S3 (for KYC document storage)
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="virtualcity-kyc-documents"

# Redis (for session caching and real-time features)
REDIS_URL="redis://localhost:6379"

# Email (for notifications)
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT="587"
SMTP_USER="apikey"
SMTP_PASS="your-sendgrid-api-key"
EMAIL_FROM="noreply@virtualcity.io"

# Responsible Gaming (GamStop integration - UK)
GAMSTOP_API_KEY="your-gamstop-key"

# Analytics
MIXPANEL_TOKEN="your-mixpanel-token"
